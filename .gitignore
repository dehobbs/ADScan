# ADScan - Git Ignore

# ---- Scan output directories ----
# Reports and artifacts generated by adscan.py are not committed.
# They may contain credential details, hostnames, and scan findings.
Reports/
Logs/

# ---- Log files ----
*.log
*.log.*

# ---- Certipy / impacket output ----
# JSON and other artifacts written to Reports/Artifacts/
*.pfx
*.ccache

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ---- Virtual environments ----
.venv/
venv/
env/
.env

# ---- Distribution / packaging ----
dist/
build/
*.egg-info/
*.egg

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Scoring config override (keep scoring.toml template, ignore local overrides) ----
# If you want to gitignore a local scoring config, name it scoring.local.toml
scoring.local.toml

# ---- Claude Code ----
CLAUDE.md
